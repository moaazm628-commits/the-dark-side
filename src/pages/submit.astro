---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Submit a Review" description="Submit your own review" />
  </head>
  <body>
    <Header />
    <main>
      <h1>✍️ Submit a Review</h1>
      <p>Share your thoughts on a movie, show, or sports event!</p>

      <form id="reviewForm">
        <div>
          <label>Your Name</label>
          <input type="text" id="author" placeholder="Your name" required />
        </div>
        <div>
          <label>Title</label>
          <input type="text" id="title" placeholder="Movie/Show/Match name" required />
        </div>
        <div>
          <label>Category</label>
          <select id="category">
            <option value="movie">🎥 Movie</option>
            <option value="show">📺 TV Show</option>
            <option value="sports">⚽ Sports</option>
          </select>
        </div>
        <div>
          <label>Rating (1-10)</label>
          <input type="number" id="rating" min="1" max="10" required />
        </div>
        <div>
          <label>Your Review</label>
          <textarea id="content" rows="6" placeholder="Write your review here..." required></textarea>
        </div>
        <button type="submit">Submit Review</button>
        <p id="message"></p>
      </form>
    </main>
    <Footer />

    <script>
      import { supabase } from '../supabase';

      document.getElementById('reviewForm').addEventListener('submit', async (e) => {
        e.preventDefault();

        const title = document.getElementById('title').value;
        const content = document.getElementById('content').value;
        const rating = parseInt(document.getElementById('rating').value);
        const author = document.getElementById('author').value;
        const category = document.getElementById('category').value;

        const { error } = await supabase.from('reviews').insert([
          { title, content, rating, author, category }
        ]);

        if (error) {
          document.getElementById('message').textContent = '❌ Something went wrong. Try again!';
        } else {
          document.getElementById('message').textContent = '✅ Review submitted successfully!';
          document.getElementById('reviewForm').reset();
        }
      });
    </script>
  </body>
</html>