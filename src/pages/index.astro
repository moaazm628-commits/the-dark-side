---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>🎬 Welcome to The Dark Side</h1>
      <p>Your go-to place for honest reviews on <strong>Movies</strong>, <strong>TV Shows</strong>, and <strong>Sports</strong>. No spoilers. No fluff. Just real opinions.</p>

      <h2>What We Cover</h2>
      <ul>
        <li>🎥 <strong>Movies</strong> — From blockbusters to hidden gems</li>
        <li>📺 <strong>TV Shows</strong> — Binge-worthy or skip-worthy?</li>
        <li>⚽ <strong>Sports</strong> — Match reviews and highlights</li>
      </ul>

      <h2>Latest Reviews</h2>
      <p>Check out our <a href="/blog">latest reviews</a> and see what's worth your time.</p>
    </main>
    <Footer />
  </body>
</html>