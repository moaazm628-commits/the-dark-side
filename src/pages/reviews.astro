---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Community Reviews" description="Reviews submitted by our community" />
  </head>
  <body>
    <Header />
    <main>
      <h1>🌍 Community Reviews</h1>
      <p>Reviews submitted by our readers!</p>
      <div id="reviews-container">Loading reviews...</div>
    </main>
    <Footer />

    <script>
      import { supabase } from '../supabase';

      async function loadReviews() {
        const { data: reviews, error } = await supabase
          .from('reviews')
          .select('*')
          .order('created_at', { ascending: false });

        const container = document.getElementById('reviews-container');

        if (error || !reviews || reviews.length === 0) {
          container.innerHTML = '<p>No reviews yet. Be the first!</p>';
          return;
        }

        container.innerHTML = reviews.map(review => `
          <div class="review-card">
            <h2>${review.title}</h2>
            <p class="meta">
              ${review.category === 'movie' ? '🎥' : review.category === 'show' ? '📺' : '⚽'}
              ${review.category} · ⭐ ${review.rating}/10 · by ${review.author}
              · ${new Date(review.created_at).toLocaleDateString()}
            </p>
            <p>${review.content}</p>
          </div>
        `).join('');
      }

      loadReviews();
    </script>
  </body>
</html>

<style>
  .review-card {
    background: #0d1426;
    border: 1px solid #4a9eff;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .meta {
    color: #4a9eff;
    font-size: 0.9rem;
  }
</style>